{
  "name": "@workcell/plugin-open-design-dashboard",
  "version": "0.1.0",
  "description": "Open Design Dashboard scaffold (D13) — surfaces design artifacts as a Workcell page slot, ready for Open Design bridge integration in a later slice.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "workcellPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "pnpm --filter @workcell/plugin-sdk ensure-build-deps",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @workcell/plugin-sdk ensure-build-deps && tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@workcell/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
