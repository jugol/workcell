{
  "name": "@workcell/plugin-modal",
  "version": "0.1.0",
  "description": "Modal sandbox provider plugin for Workcell environments",
  "license": "MIT",
  "homepage": "https://github.com/jugol/workcell",
  "bugs": {
    "url": "https://github.com/jugol/workcell/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jugol/workcell",
    "directory": "packages/plugins/sandbox-providers/modal"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "workcellPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "keywords": [
    "workcell",
    "plugin",
    "sandbox",
    "modal"
  ],
  "scripts": {
    "postinstall": "node ../../../../scripts/link-plugin-dev-sdk.mjs",
    "prebuild": "pnpm -C ../../../.. --filter @workcell/plugin-sdk ensure-build-deps",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "pnpm -C ../../../.. --filter @workcell/plugin-sdk ensure-build-deps && tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "prepack": "node -e \"var fs=require('fs');fs.rmSync('package.dev.json',{force:true});fs.cpSync('package.json','package.dev.json')\" && node ../../../../scripts/generate-plugin-package-json.mjs",
    "postpack": "if [ -f package.dev.json ]; then mv package.dev.json package.json; fi"
  },
  "dependencies": {
    "modal": "^0.7.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
